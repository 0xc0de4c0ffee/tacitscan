{
  "name": "tacitscan-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/migrate.js && node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "smoke": "tsx scripts/smoke-decode.ts"
  },
  "dependencies": {
    "@noble/curves": "1.6.0",
    "@noble/hashes": "1.5.0",
    "@scure/btc-signer": "1.5.0",
    "drizzle-orm": "0.36.0",
    "p-retry": "6.2.0",
    "postgres": "3.4.4"
  },
  "devDependencies": {
    "@types/node": "22.7.0",
    "drizzle-kit": "0.28.0",
    "tsx": "4.19.1",
    "typescript": "5.6.2"
  }
}
