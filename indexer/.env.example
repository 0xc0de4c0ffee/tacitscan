# Postgres connection string (Neon, Railway, or any Postgres)
DATABASE_URL=postgres://user:pass@host:5432/tacitscan

# Bitcoin network: "mainnet" or "signet"
BITCOIN_NETWORK=mainnet

# Bitcoin Core JSON-RPC endpoint (optional, recommended for fast backfill).
# When set, the indexer uses this as primary and falls back to ESPLORA_URL
# on errors. dRPC, QuickNode, GetBlock, or your own bitcoind all work.
# A single getblock-with-verbosity-2 call returns a whole block + all txs,
# vs Esplora's ~120 paginated calls per block — typically 50–100× faster
# for backfill.
#
# Examples:
#   dRPC:      https://lb.drpc.org/ogrpc?network=bitcoin&dkey=YOUR_DKEY
#   QuickNode: https://your-name.btc.quiknode.pro/YOUR_TOKEN/
#   GetBlock:  https://btc.getblock.io/YOUR_KEY/mainnet/
# Leave blank to use only Esplora.
BITCOIN_RPC_URL=

# Esplora REST endpoint. Used as primary when BITCOIN_RPC_URL is unset,
# or as fallback when it is set. Free public options:
#   mainnet: https://mempool.space/api  or  https://blockstream.info/api
#   signet:  https://mempool.space/signet/api  or  https://blockstream.info/signet/api
ESPLORA_URL=https://mempool.space/api

# Optional secondary Esplora endpoint used when the primary Esplora fails.
ESPLORA_FALLBACK_URL=https://blockstream.info/api

# Block height to start indexing from. The TAC asset etch — the earliest
# known Tacit mainnet envelope at the time of writing — is in block 948242,
# so we start one before to include it. Override for a different cutover.
# Indexing earlier blocks is cheap because non-Tacit txs are fast-skipped
# by a magic-byte pre-filter, but you'll still pay one Esplora call per
# block, so picking close to the real start saves wall time during backfill.
START_HEIGHT=948241

# How many blocks to keep "pending" (below confirmation depth) before
# considering them final. Per SPEC §5.9, T_PMINT cap accounting requires
# depth >= 3. We keep a small buffer to be reorg-safe.
CONFIRMATION_DEPTH=3

# Polling interval in seconds when caught up to tip
TIP_POLL_INTERVAL=30

# Max blocks per backfill batch
BACKFILL_BATCH_SIZE=10
