---
import "../styles/global.css";
import SearchBar from "../components/SearchBar.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  showHeaderSearch?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const {
  title = "tacitscan",
  description = "Block explorer for Tacit, the confidential token meta-protocol on Bitcoin. Decodes every Tacit envelope on chain — etches, transfers, mints, burns, atomic swaps.",
  ogImage = "/tacit.svg",
  showHeaderSearch = true,
  jsonLd,
} = Astro.props;
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? "tacitscan";
const network = import.meta.env.PUBLIC_NETWORK ?? "mainnet";
const brandHead = siteName.replace(/scan$/i, "");
const canonicalUrl = new URL(Astro.url.pathname, "https://tacitscan.io").toString();
const absoluteOgImage = ogImage.startsWith("http") ? ogImage : new URL(ogImage, "https://tacitscan.io").toString();
const ldArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/tacit.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="tacitscan" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content={title} />

    {
      ldArray.map((ld) => (
        <script type="application/ld+json" set:html={JSON.stringify(ld)} />
      ))
    }
  </head>
  <body>
    <div id="airdrop-banner" class="airdrop-banner" hidden>
      <a href="/airdrop" class="airdrop-banner-link">
        <span class="airdrop-banner-emoji" aria-hidden="true">🎁</span>
        <span class="airdrop-banner-text">
          <strong>Airdrop is live.</strong>
          <span class="airdrop-banner-sub">Check eligibility →</span>
        </span>
      </a>
      <button
        type="button"
        id="airdrop-banner-dismiss"
        class="airdrop-banner-dismiss"
        aria-label="Dismiss airdrop banner"
      >×</button>
    </div>
    <script is:inline>
      (function () {
        var KEY = "tacitscan.airdropBannerDismissed.v1";
        var banner = document.getElementById("airdrop-banner");
        var dismiss = document.getElementById("airdrop-banner-dismiss");
        if (!banner || !dismiss) return;
        try {
          if (localStorage.getItem(KEY) === "1") return;
        } catch (e) { /* private mode: show anyway */ }
        banner.hidden = false;
        dismiss.addEventListener("click", function (e) {
          e.preventDefault();
          banner.hidden = true;
          try { localStorage.setItem(KEY, "1"); } catch (e) { /* no-op */ }
        });
      })();
    </script>
    <header class="site">
      <div class="row">
        <a href="/" class="brand">
          <svg class="logo" viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
            <circle cx="16" cy="16" r="13" fill="none" stroke="#1e2329" stroke-width="2.5" />
            <path
              d="M17.5 7L13 22.5Q13 25 18 24"
              fill="none"
              stroke="#f7931a"
              stroke-width="2.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path d="M10 11L21 11" stroke="#f7931a" stroke-width="2.4" stroke-linecap="round" />
          </svg>
          <span>{brandHead}<span class="accent">scan</span></span>
        </a>
        <nav>
          <a href="/">Home</a>
          <a href="/assets">Assets</a>
          <a href="/activity">Activity</a>
          <a href="/airdrop">Airdrop</a>
        </nav>
        {showHeaderSearch && <SearchBar />}
        <span class="net-pill">{network}</span>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <span class="footer-part">Block explorer for <a href="https://github.com/z0r0z/tacit" rel="noreferrer">Tacit</a></span>
      <span class="footer-sep" aria-hidden="true">·</span>
      <span class="footer-part">data via <a href="https://drpc.org" rel="noreferrer">dRPC</a> + <a href="https://mempool.space" rel="noreferrer">mempool.space</a></span>
      <span class="footer-sep" aria-hidden="true">·</span>
      <span class="footer-part">open source on <a href="https://github.com/nerderlyne/tacitscan" rel="noreferrer">GitHub</a></span>
    </footer>
  </body>
</html>
