---
import { resolveImageUri } from "../lib/format";
import { identiconSvg } from "../lib/identicon";

interface Props {
  imageUri: string | null;
  resolvedImageUrl?: string | null;
  assetId: string;
  ticker: string;
  size?: number;
  rounded?: boolean;
}
const { imageUri, resolvedImageUrl, assetId, ticker, size = 28, rounded = true } = Astro.props;
const src = resolvedImageUrl ?? resolveImageUri(imageUri);
const identicon = src ? "" : identiconSvg(assetId, size);
---

<span
  class:list={["asset-thumb", { rounded }]}
  style={`width:${size}px;height:${size}px`}
  title={ticker}
>
  {
    src ? (
      <img
        src={src}
        alt={ticker}
        loading="lazy"
        decoding="async"
        width={size}
        height={size}
      />
    ) : (
      <span class="identicon" set:html={identicon} />
    )
  }
</span>
