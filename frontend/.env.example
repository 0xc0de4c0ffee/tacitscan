# Same Postgres the indexer writes to. On Vercel + Neon, use the pooled
# connection string (-pooler in the host) for serverless compatibility.
DATABASE_URL=postgres://user:pass@host-pooler:5432/tacitscan?sslmode=require

# Public name shown in the UI. "tacitscan", "TacitScan (signet)", etc.
PUBLIC_SITE_NAME=tacitscan
PUBLIC_NETWORK=mainnet
